{
  "name": "@xubylele/schema-forge-core",
  "version": "1.3.1",
  "description": "Core engine for Schema Forge DSL parsing, diffing and SQL generation",
  "license": "ISC",
  "author": "xubylele <diazxavier27@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xubylele/schema-forge-core.git"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./browser": {
      "import": "./dist/browser.js",
      "types": "./dist/browser.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc && npm run build:browser",
    "build:browser": "tsup --config tsup.browser.config.ts",
    "test": "vitest run",
    "dev": "tsc -w"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.0.18"
  }
}